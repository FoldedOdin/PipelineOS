{
  "name": "@pipeline-os/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "express-rate-limit": "^8.3.2",
    "mongoose": "9.4.1",
    "p-queue": "9.1.2",
    "pino": "9.6.0",
    "pino-http": "10.3.0",
    "ws": "8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/express": "5.0.0",
    "@types/node": "22.10.5",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "6.0.2",
    "@types/ws": "8.18.1",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0",
    "vitest": "4.1.3"
  },
  "engines": {
    "node": ">=20"
  }
}
