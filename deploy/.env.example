# Used by Docker Compose (copy to deploy/.env).
#
# API Service
PORT=3001
MONGODB_URI=mongodb://mongo:27017/pipelineos
# Must match the secret configured on the GitHub webhook
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
# GitHub App credentials for Contents API (fetch .pipelineos.yml)
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
# Shared secret for runner -> API internal endpoints
INTERNAL_API_KEY=random_string_here
# Reserved for future dashboard auth
JWT_SECRET=random_string_here
NODE_ENV=development

# Runner Service
API_URL=http://api:3001
INTERNAL_API_KEY=same_as_above
MAX_CONCURRENT_RUNS=3
DOCKER_SOCKET=/var/run/docker.sock
DEFAULT_STAGE_TIMEOUT_MINUTES=10

# Frontend build-time (Vite); use host-accessible URLs when developing with Compose
VITE_API_URL=http://localhost:3001
VITE_WS_URL=ws://localhost:3001
