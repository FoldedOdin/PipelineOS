{
  "name": "@pipeline-os/runner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "dockerode": "4.0.10",
    "dotenv": "16.4.5",
    "pino": "9.6.0",
    "yaml": "2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "@types/dockerode": "4.0.1",
    "@types/node": "22.10.5",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2",
    "tsx": "4.21.0",
    "typescript": "5.7.2",
    "typescript-eslint": "8.19.0",
    "vitest": "2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
